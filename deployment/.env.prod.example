# ---------------------------------------------------------------------------
# Production env for the Skooly backend. Copy to .env.prod and fill in.
#   cp .env.prod.example .env.prod   &&   nano .env.prod
# NEVER commit .env.prod.
# ---------------------------------------------------------------------------

DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=false

# Generate strong values, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-50+-random-chars
JWT_SECRET=replace-with-50+-random-chars

# Host the API is served as (via the tunnel). CORS = the frontend origin(s).
ALLOWED_HOSTS=api.smartskool.in
CORS_ALLOWED_ORIGINS=https://www.smartskool.in,https://smartskool.in

# --- Neon Postgres (managed) ---------------------------------------------
# Use the POOLED connection host from the Neon dashboard (…-pooler…).
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=replace-with-neon-password
DB_HOST=ep-xxxx-xxxx-pooler.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_SSLMODE=require
DB_CONN_MAX_AGE=60

# --- Cache / Celery: no Redis in prod ------------------------------------
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CELERY_TASK_ALWAYS_EAGER=true

# --- Media storage: Cloudflare R2 ----------------------------------------
USE_R2=true
R2_ACCESS_KEY=replace
R2_SECRET_KEY=replace
R2_BUCKET=smartskool-media
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# --- Do NOT seed the demo school in prod ---------------------------------
SKOOLY_SEED_DEMO=false

# --- Runtime -------------------------------------------------------------
GUNICORN_WORKERS=3

# --- Cloudflare Tunnel ----------------------------------------------------
# Zero Trust → Networks → Tunnels → create tunnel → copy the token.
# Add a public hostname: api.smartskool.in  ->  http://api:8000
CLOUDFLARE_TUNNEL_TOKEN=replace-with-tunnel-token

# --- Optional ------------------------------------------------------------
# SENTRY_DSN=
